# --- Frontend (Vite) — copy to .env and fill values ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Node manual API (gamification, manual submissions, admin calls from browser)
# Default port matches package.json backend scripts (7001). No trailing slash.
# Production on Vercel: if this is unset at build time, vite.config.ts defaults to
# https://lab-record-system-moy2.onrender.com when VERCEL=1 (override anytime here or in Vercel).
# Local dev: keep this as http://localhost:7001 (or run `npm run dev` for API). Pointing at
# a public Render URL without that origin in CORS will cause CORS errors; the app falls back to Supabase.
VITE_MANUAL_API_URL=http://localhost:7001

# Internal marks caps (optional overrides)
VITE_INTERNAL_EXPERIMENT_MAX_MARK=10
VITE_INTERNAL_MARKS_MAX=20

# Optional: require department for admins during role setup
VITE_REQUIRE_ADMIN_DEPARTMENT=false

# Optional: proctor service (see backend/proctor)
VITE_PROCTOR_API_URL=http://127.0.0.1:8001

# --- Backend (Node server.cjs) — load via dotenv from project root ---
# Same Supabase project; use service role only on the server, never in Vite.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket for PDF manuals (defaults to "manuals" in code)
SUPABASE_MANUALS_BUCKET=manuals

# Optional: enable OCR path for manual PDF parsing (server)
MANUAL_ENABLE_PDF_OCR=false

# Comma-separated department list for admin UI (optional)
ADMIN_DEPARTMENT_CATALOG=

# Code runner / jobs (optional)
RUNNER_PORT=7001
JOBS_DIR=./jobs

# Local LLM evaluator (optional, free local model via Ollama)
# Install Ollama and run a model, e.g.:
#   ollama pull llama3.2:3b
#   ollama serve
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
# Docker /run timeout (ms). First `docker pull` of a language image can take minutes; default 180000.
# DOCKER_RUN_TIMEOUT_MS=180000
# Execution: auto = Docker, then Piston→Judge0 if docker missing (good for Render without Docker).
# docker = Docker only | piston = Piston then Judge0 if Piston throws | judge0 = Judge0 CE only
CODE_RUNNER=auto
# PISTON_API_URL=https://emkc.org/api/v2/piston/execute
# JUDGE0_API_URL=https://ce.judge0.com

# --- Production / hosting ---
# Public URL of your deployed frontend (no trailing slash). Comma-separate for multiple (preview + prod).
# Required on the Node server so CORS allows the browser to call /api/* (localhost is always allowed).
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourcollege.edu
# FRONTEND_URL=https://your-app.vercel.app
# On Render, any https://*.vercel.app origin is allowed for API calls unless you set:
# CORS_ALLOW_VERCEL_PREVIEWS=false
# Emergency only (public API): CORS_ALLOW_ALL=true

# --- API hardening (server.cjs) — optional overrides ---
# TRUST_PROXY=1                    # Behind reverse proxy; fixes rate-limit client IP
# JSON_BODY_LIMIT=1mb              # express.json max body size
# RATE_LIMIT_GLOBAL_MAX=600      # Requests / window (default 15 min) for whole API
# RATE_LIMIT_RUN_MAX=60          # Stricter cap for POST /run and POST /api/run-java
# RATE_LIMIT_AI_MAX=20           # Per-minute cap for POST /api/ai/local-evaluate
# RUN_MAX_CODE_CHARS=120000      # Max source length for /run (DoS guard)
